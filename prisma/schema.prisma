// نظام إدارة حلقات تحفيظ القرآن الكريم
// schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ المستخدمون والأدوار ============

enum Role {
  DEVELOPER // المطورة - صلاحيات كاملة فوق المديرة
  ADMIN // المديرة
  SUPERVISOR // المشرفة
  TEACHER // المعلمة
}

enum UserStatus {
  PENDING // بانتظار موافقة المديرة
  ACTIVE // مفعّل
  REJECTED // مرفوض
  SUSPENDED // موقوف
}

model User {
  id                  String     @id @default(cuid())
  name                String
  nationalIdHash      String     @unique // بصمة SHA-256 لرقم الهوية/الإقامة (للتحقق من التكرار وتسجيل الدخول)
  nationalIdEncrypted String // رقم الهوية/الإقامة مشفّر (AES-256-GCM) - تراه المديرة فقط
  nationalIdLastFour  String // آخر 4 أرقام تُعرض بدون فك تشفير
  passwordHash        String
  role                Role
  status              UserStatus @default(PENDING)
  phone               String?
  avatarUrl           String? // صورة الحساب (اختيارية) - تُخزَّن كـ data URL مصغّرة
  lastSeenAt          DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // حماية تسجيل الدخول من محاولات التخمين المتكررة
  failedLoginAttempts Int       @default(0) // عدد محاولات الدخول الفاشلة المتتالية
  lockedUntil         DateTime? // إن كان في المستقبل، الحساب موقوف مؤقتًا عن الدخول

  // بيانات إضافية خاصة بالمعلمة/المشرفة (مطلوبة عند الإضافة/التعديل) - تُستخدم في صفحة تفاصيل الحلقة
  nationality     String? // الجنسية
  age             Int? // العمر
  educationLevel  String? // المؤهل الدراسي
  residence       String? // مقر الإقامة
  memorizedAmount String? // مقدار حفظها من القرآن الكريم
  experience      String? // الخبرة

  teacherHalaqa     Halaqa?   @relation("TeacherHalaqa")
  supervisedHalaqat Halaqa[]  @relation("SupervisorHalaqat")
  sessions          Session[]

  @@index([role, status])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ المسارات ============
// تجميع الحلقات ضمن مسارات كبرى (مثال: مسار الجمان، مسار الرواء، مسار رواس)

model Track {
  id        String   @id @default(cuid())
  name      String   @unique
  imageUrl  String? // صورة المسار (اختيارية) - تُخزَّن كـ data URL مصغّرة
  createdAt DateTime @default(now())

  halaqat Halaqa[]
}

// ============ البرامج (سجل الإنجازات) ============
// سجل مستقل بالبرامج التي تنفذها المقرأة (منفصل عن الحلقات والطالبات)

model Program {
  id             String   @id @default(cuid())
  name           String
  description    String? // وصف البرنامج
  duration       String // مدة البرنامج (نص حر، مثل: 3 أشهر)
  academicYear   String // العام الدراسي، مثال: 1447هـ
  reportUrl      String? // ملف التقرير الختامي (PDF أو صورة) - يُخزَّن كـ data URL
  reportFileName String? // اسم الملف الأصلي، لعرضه عند التحميل
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============ الحلقات ============

enum HalaqaCategory {
  MOTHERS // أمهات
  GIRLS // فتيات
  CHILDREN // أطفال
}

model Halaqa {
  id           String          @id @default(cuid())
  name         String
  time         String // وقت الحلقة (نص حر، مثل: بعد صلاة العصر)
  category     HalaqaCategory? // تصنيف الحلقة: أمهات/فتيات/أطفال
  isActive     Boolean         @default(true)
  teacherId    String?         @unique
  teacher      User?           @relation("TeacherHalaqa", fields: [teacherId], references: [id])
  supervisorId String?
  supervisor   User?           @relation("SupervisorHalaqat", fields: [supervisorId], references: [id])
  trackId      String?
  track        Track?          @relation(fields: [trackId], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  students       Student[]
  attendanceLogs AttendanceLog[]

  @@index([supervisorId])
  @@index([trackId])
}

// ============ الطالبات ============

model Student {
  id                  String   @id @default(cuid())
  name                String
  nationality         String
  halaqaId            String
  halaqa              Halaqa   @relation(fields: [halaqaId], references: [id])
  nationalIdEncrypted String? // رقم هوية الطالبة مشفّر (AES-256-GCM) - تراه المديرة/المشرفة فقط
  nationalIdLastFour  String? // آخر 4 أرقام تُعرض بدون فك تشفير
  age                 Int? // العمر
  educationLevel      String? // المؤهل الدراسي
  residence           String? // مقر الإقامة
  memorizedAmount     String? // مقدار الحفظ من القرآن الكريم (وصف عام عند التسجيل)
  memorizedPagesTotal Int      @default(0) // إجمالي عدد الأوجه المحفوظة
  currentQuota        String? // نصاب الحفظ الحالي
  notes               String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  memorizationRecords MemorizationRecord[]
  examGrades          ExamGrade[]
  attendanceRecords   StudentAttendance[]

  @@index([halaqaId])
}

// سجل يومي لتقدم الحفظ (يُبنى منه الأرشيف والشهادات)
model MemorizationRecord {
  id             String   @id @default(cuid())
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  date           DateTime
  pagesMemorized Int // عدد الأوجه المحفوظة في هذا التسجيل
  quota          String? // النصاب المحدد لهذا اليوم
  enteredById    String // المعلمة التي أدخلت البيانات
  createdAt      DateTime @default(now())

  @@index([studentId, date])
}

// درجات الاختبارات (تُستخدم للأرشفة والشهادات)
model ExamGrade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  quota       String // النصاب المختبر فيه
  grade       Float
  maxGrade    Float    @default(100)
  examDate    DateTime
  enteredById String
  createdAt   DateTime @default(now())

  @@index([studentId])
}

// سجل حضور الحلقة اليومي (يُستخدم لتنبيهات عدم التسجيل ولوحة الشرف)
model AttendanceLog {
  id             String    @id @default(cuid())
  halaqaId       String
  halaqa         Halaqa    @relation(fields: [halaqaId], references: [id])
  date           DateTime
  teacherPresent Boolean   @default(true)
  dataSubmitted  Boolean   @default(false)
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())

  studentAttendance StudentAttendance[]

  @@unique([halaqaId, date])
  @@index([date])
}

model StudentAttendance {
  id              String        @id @default(cuid())
  attendanceLogId String
  attendanceLog   AttendanceLog @relation(fields: [attendanceLogId], references: [id])
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  present         Boolean       @default(true)

  @@unique([attendanceLogId, studentId])
}

// ============ إعدادات الموقع العامة (صف وحيد) ============
// تُستخدم حاليًا لتخزين شعار الموقع القابل للتعديل من لوحة الإعدادات

model AppSettings {
  id        String   @id @default("main")
  logoUrl   String? // شعار الموقع (اختياري) - يُخزَّن كـ data URL، وإلا يُعرض الشعار الافتراضي
  updatedAt DateTime @updatedAt
}

// ============ سجل الحركات (Audit Log) ============
// يسجّل كل عملية إضافة/تعديل/حذف يقوم بها المستخدمون لمراجعتها من قبل المديرة

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actorName   String
  actorRole   Role
  action      String // مفتاح العملية، مثال: STUDENT_UPDATE
  targetType  String // نوع الهدف، مثال: Student, Halaqa, User
  targetId    String?
  targetLabel String // اسم مقروء للهدف، مثال: اسم الطالبة
  message     String // وصف العملية بصيغة عربية، مثال: "عدّلت بيانات الطالبة"
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
}
